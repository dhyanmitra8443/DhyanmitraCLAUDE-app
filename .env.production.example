# Template for the real .env.production file, which lives only on the
# server (typed there directly, never committed - see .gitignore's
# `.env*` rule). Copy this file to .env.production on the server and fill
# in real values before `docker compose -f docker-compose.prod.yml up -d`.
#
# Ref: SRS 18.7 - "Production credentials shall never be stored in source
# control." Every var below is read by docker-compose.prod.yml.

DB_NAME=dhyanmitra_prod_db
DB_USERNAME=dhyanmitra_prod_user
# Generate with: openssl rand -base64 24
DB_PASSWORD=

# Generate with: openssl rand -base64 48
JWT_SECRET=
# Generate with: openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=

CORS_ALLOWED_ORIGINS=https://dhyanmitra.in
FRONTEND_URL=https://dhyanmitra.in

# Reuse the same Gmail SMTP already validated in dev, or switch to a
# transactional-email provider before real user volume.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=admin@dhyanmitra.in

# Optional at first boot - RazorpayApiClient rejects order creation with a
# clear error rather than misbehaving if these are blank. Fill in once real
# live-mode Razorpay credentials exist (see admin Settings > Payment Gateway
# for the equivalent per-field override, which takes precedence over these).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
